{% extends 'base.html.twig' %}
{% block title %}Connexion — Diamond Forum{% endblock %}

{% block base_stylesheets %}{% endblock %}

{% block navbar %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/login.css') }}">
{% endblock %}

{% block body %}
<div class="df-login">
    <div class="df-login__grid">
        <section class="df-login__visual">
            <img src="{{ asset('images/login/baseball-stadium.png') }}" alt="Stade de baseball illuminé au crépuscule">
            <div class="df-login__visual-overlay"></div>

            <div class="df-login__visual-content">
                <div class="df-login__brand">
                    <span class="df-login__brand-badge">DF</span>
                    <span class="df-login__brand-name">DIAMOND FORUM</span>
                </div>

                <div class="df-login__pitch">
                    <span class="df-login__pitch-badge">+{{ userCount|default(48000) }} membres actifs</span>
                    <h2>Rejoins la ligue des <span class="df-accent">vrais fans</span> de baseball.</h2>
                    <p>
                        Débats enflammés, analyses de stats, pronostics et fantasy leagues.
                        Tout se passe ici, de la première manche à la neuvième.
                    </p>
                </div>
            </div>
        </section>

        <section class="df-login__form-panel">
            <div class="df-login__form-wrap" data-controller="login-form">
                <div class="df-login__mobile-brand">
                    <span class="df-login__brand-badge">DF</span>
                    <span class="df-login__brand-name">DIAMOND FORUM</span>
                </div>

                <h1>Content de te revoir</h1>
                <p>Connecte-toi pour reprendre les débats et suivre les résultats de la MLB.</p>

                {% if app.user %}
                    <div class="df-login__alert" style="border-color: rgba(16,185,129,0.4); background: rgba(16,185,129,0.1); color: var(--df-green);">
                        <span>Tu es déjà connecté en tant que {{ app.user.userIdentifier }}. <a href="{{ path('app_logout') }}" style="color: var(--df-green); text-decoration: underline;">Se déconnecter</a></span>
                    </div>
                {% endif %}

                {% if error %}
                    <div class="df-login__alert" role="alert">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                    </div>
                {% endif %}

                <form class="df-login__form" method="post">
                    <div class="df-login__field">
                        <label for="email">Adresse email</label>
                        <div class="df-login__input-wrap">
                            <svg class="df-icon-left" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                            <input
                                id="email"
                                name="email"
                                type="email"
                                autocomplete="email"
                                value="{{ last_username }}"
                                placeholder="toi@diamondforum.com"
                                required
                                autofocus
                            >
                        </div>
                    </div>

                    <div class="df-login__field">
                        <div class="df-login__field-head">
                            <label for="password">Mot de passe</label>
                            <a href="#">Mot de passe oublié ?</a>
                        </div>
                        <div class="df-login__input-wrap">
                            <svg class="df-icon-left" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            <input
                                id="password"
                                name="password"
                                type="password"
                                autocomplete="current-password"
                                placeholder="••••••••"
                                required
                                class="has-toggle"
                                data-login-form-target="password"
                            >
                            <button
                                type="button"
                                class="df-login__toggle-visibility"
                                data-action="login-form#toggleVisibility"
                                aria-label="Afficher le mot de passe"
                            >
                                <span data-login-form-target="toggleIcon">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8Z"/><circle cx="12" cy="12" r="3"/></svg>
                                </span>
                            </button>
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <label class="df-login__remember">
                        <input type="checkbox" name="_remember_me" checked>
                        Rester connecté
                    </label>

                    <button type="submit" class="df-login__submit">Entrer sur le terrain</button>
                </form>

                <p class="df-login__footer-text">
                    Pas encore membre ? <a href="{{ path('app_register') }}">Crée ton compte</a>
                </p>
            </div>
        </section>
    </div>
</div>
{% endblock %}
