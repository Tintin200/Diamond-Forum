<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        {% block base_stylesheets %}
        <link rel="stylesheet" type="text/css" href="{{ asset('styles/base.css') }}">
        <link rel="stylesheet" type="text/css" href="{{ asset('styles/professional-theme.css') }}">
        <link rel="stylesheet" type="text/css" href="{{ asset('styles/index.css') }}">
        {% endblock %}
        <title>{% block title %}Baseball Dashboard{% endblock %}</title>
        {% block stylesheets %}
            {{ importmap('app') }}
        {% endblock %}
    </head>
    <body>
    {% block navbar %}
    <div class="menu">
        <a href="{{ path('app_home')}}" class="{{ app.current_route == 'app_home' ? 'active' : '' }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></g></svg>
            <span>Accueil</span>
        </a>
        <a href="{{ path('app_chat')}}" class="{{ app.current_route == 'app_chat' ? 'active' : '' }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 10a2 2 0 0 1-2 2H6.828a2 2 0 0 0-1.414.586l-2.202 2.202A.71.71 0 0 1 2 14.286V4a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2zm4-1a2 2 0 0 1 2 2v10.286a.71.71 0 0 1-1.212.502l-2.202-2.202A2 2 0 0 0 17.172 19H10a2 2 0 0 1-2-2v-1"/></svg>
            <span>Forum</span>
        </a>
        <a href="{{ path('app_news')}}" class="{{ app.current_route == 'app_news' ? 'active' : '' }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M15 18h-5m8-4h-8m-6 8h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-4 0v-9a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="10" y="6" rx="1"/></g></svg>
            <span>News</span>
        </a>
        <a href="{{ path('app_about') }}" class="{{ app.current_route == 'app_about' ? 'active' : '' }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4m0-4h.01"/></g></svg>
            <span>A Propos</span>
        </a>
        {% if app.user %}
            <a href="{{ path('app_logout') }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="1.3rem" height="1.3rem" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                <span>Déconnexion</span>
            </a>
        {% else %}
            <a href="{{ path('app_login') }}" class="{{ app.current_route == 'app_login' or app.current_route == 'app_register' ? 'active' : '' }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="1.3rem" height="1.3rem" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                <span>Connexion</span>
            </a>
        {% endif %}
    </div>
    {% endblock %}
    {% block body %}{% endblock %}

    {% block javascripts %}{% endblock %}
    </body>
</html>
