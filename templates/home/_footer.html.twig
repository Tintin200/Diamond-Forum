<footer class="df-footer">
    <div class="df-container">
        <div class="df-footer__cta" data-reveal>
            <h2>
                <span style="display:block;">PRÊT À REJOINDRE</span>
                <span style="display:block;" class="df-accent">LE DIAMANT ?</span>
            </h2>
        </div>

        {% if not app.user %}
        <div class="df-footer__form" data-reveal>
            <form action="{{ path('app_register') }}" method="get" class="df-footer__form-row">
                <input type="email" name="email" placeholder="ton@email.com" required>
                <button type="submit" class="df-btn df-btn--primary">Créer un compte</button>
            </form>
            <p>Rejoins des milliers de fans. Pas de spam, que du baseball.</p>
        </div>
        {% endif %}

        <div class="df-footer__links" data-reveal>
            <div>
                <h4>Le Forum</h4>
                <ul>
                    <li><a href="{{ path('app_chat') }}">Discussions</a></li>
                    <li><a href="{{ path('app_news') }}">Actualités</a></li>
                    <li><a href="{{ path('app_about') }}">Guide des Stades</a></li>
                    <li><a href="#classement">Classement</a></li>
                </ul>
            </div>
            <div>
                <h4>Boutique</h4>
                <ul>
                    <li><a href="#starter">Starter Pack</a></li>
                    <li><a href="#starter">Battes</a></li>
                    <li><a href="#starter">Gants</a></li>
                    <li><a href="#starter">Accessoires</a></li>
                </ul>
            </div>
            <div>
                <h4>Communauté</h4>
                <ul>
                    <li><a href="{{ path('app_home') }}">Accueil</a></li>
                    <li><a href="#scores">Scores</a></li>
                    <li><a href="{{ path('app_news') }}">News</a></li>
                    <li><a href="{{ path('app_about') }}">A Propos</a></li>
                </ul>
            </div>
            <div>
                <h4>Légal</h4>
                <ul>
                    <li><a href="#">Confidentialité</a></li>
                    <li><a href="#">Conditions</a></li>
                    <li><a href="#">Cookies</a></li>
                </ul>
            </div>
        </div>

        <div class="df-footer__bottom">
            <div class="df-footer__brand">
                <span class="df-footer__brand-badge">⚾</span>
                <span class="df-name"><span style="color:#fff;">Diamond</span><span style="color:#10B981;"> Forum</span></span>
            </div>
            <p class="df-footer__legal">© {{ "now"|date("Y") }} Diamond Forum. Tous droits réservés.</p>
            <p class="df-footer__legal">fait avec passion ⚾</p>
        </div>
    </div>

    <div class="df-footer__watermark">MLB</div>
</footer>
