{% extends 'base.html.twig' %}

{% block title %}Accueil - Diamond Forum{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/home.css') }}">
{% endblock %}

{% block body %}
<main>
    <div class="profile-header-bar">
        <h1>⚾ Bienvenue sur Diamond Forum</h1>
        {% if app.user %}
        <button class="profile-toggle-btn" id="profileToggle" aria-label="Mon Profil">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="profile-icon">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
            </svg>
        </button>
        {% endif %}
    </div>

    <p>Le point de rencontre ultime pour tous les passionnés de baseball. Échangez sur la MLB, vos équipes favorites et les dernières actus du terrain.</p>

    <section class="live-games-section" style="margin-top: 30px;">
        <h2>⚾ Matchs & Scores du Jour</h2>
        <div class="grid">
            {% for game in games %}
                <div class="card game-card">
                    <div class="game-header">
                        {% set statusClass = 'primary' %}
                        {% if game.status.short == 'LIVE' or game.status.short == 'LIVE (6th Inning)' %}
                            {% set statusClass = 'danger' %}
                        {% elseif game.status.short == 'FT' or game.status.short == 'Finished' %}
                            {% set statusClass = 'success' %}
                        {% endif %}
                        <span class="badge {{ statusClass }}">{{ game.status.long }}</span>
                        <span class="game-time text-secondary">{{ game.time }}</span>
                    </div>
                    <div class="game-teams">
                        <div class="team">
                            <div style="display: flex; align-items: center; gap: 8px; overflow: hidden;">
                                {% if game.teams.home.logo %}
                                    <img src="{{ game.teams.home.logo }}" alt="{{ game.teams.home.name }}" class="team-logo">
                                {% endif %}
                                <span class="team-name">{{ game.teams.home.name }}</span>
                            </div>
                            <span class="team-score">
                                {{ game.scores.home.total is not null ? game.scores.home.total : '-' }}
                            </span>
                        </div>
                        <div class="team">
                            <div style="display: flex; align-items: center; gap: 8px; overflow: hidden;">
                                {% if game.teams.away.logo %}
                                    <img src="{{ game.teams.away.logo }}" alt="{{ game.teams.away.name }}" class="team-logo">
                                {% endif %}
                                <span class="team-name">{{ game.teams.away.name }}</span>
                            </div>
                            <span class="team-score">
                                {{ game.scores.away.total is not null ? game.scores.away.total : '-' }}
                            </span>
                        </div>
                    </div>
                    <div class="game-footer text-muted" style="font-size: 0.75rem; border-top: 1px solid var(--border-color); padding-top: 8px; margin-top: auto;">
                        🏆 {{ game.league.name }}
                    </div>
                </div>
            {% else %}
                <p>Aucun match aujourd'hui.</p>
            {% endfor %}
        </div>
    </section>

    <section class="mlb-standings-section">
        <h2>🏆 Classement Général de la MLB (Saison {{ standingsSeason }})</h2>
        <p class="text-secondary" style="margin-bottom: 20px;">Retrouvez les positions des franchises majeures de la Ligue Américaine et Nationale.</p>
        <div class="grid">
            <!-- American League -->
            <div class="card standings-card" style="padding: 16px;">
                <h3 style="display: flex; align-items: center; gap: 8px; border-bottom: 2px solid var(--border-color); padding-bottom: 10px; margin-bottom: 15px; font-size: 1.1rem;">
                    🇺🇸 Ligue Américaine (AL)
                </h3>
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 0;">
                        <thead>
                            <tr style="background: var(--bg-main);">
                                <th style="padding: 8px 10px; width: 40px; text-align: center;">Pos</th>
                                <th style="padding: 8px 10px;">Franchise</th>
                                <th style="padding: 8px 10px; text-align: center;">V</th>
                                <th style="padding: 8px 10px; text-align: center;">D</th>
                                <th style="padding: 8px 10px; text-align: center;">%</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in americanLeague %}
                                <tr>
                                    <td style="padding: 10px; text-align: center; font-weight: 700; color: var(--text-secondary);">{{ item.position }}</td>
                                    <td style="padding: 10px; font-weight: 600;">
                                        <div style="display: flex; align-items: center; gap: 8px;">
                                            {% if item.team.logo %}
                                                <img src="{{ item.team.logo }}" alt="{{ item.team.name }}" style="width: 22px; height: 22px; object-fit: contain; background: var(--bg-main); padding: 1px; border-radius: 2px; border: 1px solid var(--border-color);">
                                            {% endif %}
                                            <span style="font-size: 0.9rem; color: var(--text-primary);">{{ item.team.name }}</span>
                                        </div>
                                    </td>
                                    <td style="padding: 10px; text-align: center; font-weight: 700; color: var(--text-primary);">{{ item.games.win.total }}</td>
                                    <td style="padding: 10px; text-align: center; color: var(--accent-red);">{{ item.games.lose.total }}</td>
                                    <td style="padding: 10px; text-align: center; font-size: 0.85rem; color: var(--text-secondary);">{{ item.games.win.percentage }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" style="text-align: center; padding: 20px;">Aucune donnée.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- National League -->
            <div class="card standings-card" style="padding: 16px;">
                <h3 style="display: flex; align-items: center; gap: 8px; border-bottom: 2px solid var(--border-color); padding-bottom: 10px; margin-bottom: 15px; font-size: 1.1rem;">
                    🦅 Ligue Nationale (NL)
                </h3>
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 0;">
                        <thead>
                            <tr style="background: var(--bg-main);">
                                <th style="padding: 8px 10px; width: 40px; text-align: center;">Pos</th>
                                <th style="padding: 8px 10px;">Franchise</th>
                                <th style="padding: 8px 10px; text-align: center;">V</th>
                                <th style="padding: 8px 10px; text-align: center;">D</th>
                                <th style="padding: 8px 10px; text-align: center;">%</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in nationalLeague %}
                                <tr>
                                    <td style="padding: 10px; text-align: center; font-weight: 700; color: var(--text-secondary);">{{ item.position }}</td>
                                    <td style="padding: 10px; font-weight: 600;">
                                        <div style="display: flex; align-items: center; gap: 8px;">
                                            {% if item.team.logo %}
                                                <img src="{{ item.team.logo }}" alt="{{ item.team.name }}" style="width: 22px; height: 22px; object-fit: contain; background: var(--bg-main); padding: 1px; border-radius: 2px; border: 1px solid var(--border-color);">
                                            {% endif %}
                                            <span style="font-size: 0.9rem; color: var(--text-primary);">{{ item.team.name }}</span>
                                        </div>
                                    </td>
                                    <td style="padding: 10px; text-align: center; font-weight: 700; color: var(--text-primary);">{{ item.games.win.total }}</td>
                                    <td style="padding: 10px; text-align: center; color: var(--accent-red);">{{ item.games.lose.total }}</td>
                                    <td style="padding: 10px; text-align: center; font-size: 0.85rem; color: var(--text-secondary);">{{ item.games.win.percentage }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" style="text-align: center; padding: 20px;">Aucune donnée.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

    <section>
        <h2>Fonctionnalités du Forum</h2>
        <div class="grid">
            <div class="card">
                <h3>💬 Discussions Bleachers</h3>
                <p>Échangez avec une communauté de fans passionnés. Débattez sur les matchs d'hier soir, les transferts à venir et les stratégies de jeu.</p>
                <a href="{{ path('app_chat') }}" class="btn">Accéder au Forum</a>
            </div>

            <div class="card">
                <h3>📡 Actualités de la MLB</h3>
                <p>Restez informé avec des analyses complètes de matchs, des rapports de blessures, et les scoops les plus chauds des ligues majeures.</p>
                <a href="{{ path('app_news') }}" class="btn">Lire les Actus</a>
            </div>

            <div class="card">
                <h3>🏟️ Guide des Stades</h3>
                <p>Découvrez l'histoire des temples du baseball, du Fenway Park au Yankee Stadium, et partagez vos expériences de visite sur votre profil.</p>
                <a href="{{ path('app_about') }}" class="btn">En savoir plus</a>
            </div>
        </div>
    </section>

    <section>
        <h2>Le Forum en Chiffres</h2>
        <div class="grid">
            <div class="card text-center">
                <h3 style="font-size: 2.8rem; color: var(--accent-green); margin: 20px 0;">{{ userCount }}</h3>
                <p class="text-secondary">Fans Actifs</p>
            </div>

            <div class="card text-center">
                <h3 style="font-size: 2.8rem; color: var(--accent-red); margin: 20px 0;">{{ articleCount }}</h3>
                <p class="text-secondary">Sujets de Discussion</p>
            </div>

            <div class="card text-center">
                <h3 style="font-size: 2.8rem; color: var(--accent-green); margin: 20px 0;">{{ likeCount }}</h3>
                <p class="text-secondary">Appréciations Partagées</p>
            </div>
        </div>
    </section>


    <section>
        <h2>Comment commencer ?</h2>
        <ol>
            <li><strong>Créez votre profil de Fan</strong> - Configurez vos préférences et sélectionnez vos franchises favorites (Yankees, Red Sox, Dodgers...).</li>
            <li><strong>Rejoignez la discussion</strong> - Donnez votre avis dans les salons de chat d'avant-match et commentez les manches en direct.</li>
            <li><strong>Découvrez les actus</strong> - Parcourez les derniers articles publiés par nos rédacteurs spécialisés.</li>
            <li><strong>Marquez vos favoris</strong> - Aimez des articles et gérez la liste des stades que vous avez visités.</li>
        </ol>
    </section>
</main>

{# Profile Sidebar Drawer #}
<div class="profile-drawer-backdrop" id="profileBackdrop"></div>
<div class="profile-drawer" id="profileDrawer">
    <div class="profile-drawer-header">
        <h2>👤 Informations de Compte</h2>
        <button class="profile-close-btn" id="profileClose">&times;</button>
    </div>
    <div class="profile-drawer-body">
        {% if app.user %}
            <div class="profile-avatar-large">
                {{ app.user.email|slice(0, 1)|upper }}
            </div>
            <div class="profile-info-group">
                <span class="profile-info-label">Email</span>
                <span class="profile-info-value">{{ app.user.email }}</span>
            </div>
            <div class="profile-info-group">
                <span class="profile-info-label">Rôles</span>
                <div class="profile-roles-badges">
                    {% for role in app.user.roles %}
                        {% set roleLabel = 'Utilisateur' %}
                        {% set badgeColor = 'var(--accent-green)' %}
                        
                        {% if role == 'ROLE_ADMIN' %}
                            {% set roleLabel = 'Administrateur' %}
                            {% set badgeColor = 'var(--accent-red)' %}
                        {% elseif role == 'ROLE_MOD' or role == 'ROLE_MODERATOR' %}
                            {% set roleLabel = 'Modérateur' %}
                            {% set badgeColor = 'var(--warning)' %}
                        {% endif %}
                        
                        <span class="badge" style="background-color: {{ badgeColor }}; color: white; padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">{{ roleLabel }}</span>
                    {% endfor %}
                </div>
            </div>
            <hr class="profile-divider">
            <h3>📊 Activité sur Diamond Forum</h3>
            <div class="profile-stats-grid">
                <div class="profile-stat-card">
                    <span class="profile-stat-icon">✍️</span>
                    <span class="profile-stat-number">{{ app.user.articles|length }}</span>
                    <span class="profile-stat-text">Articles</span>
                </div>
                <div class="profile-stat-card">
                    <span class="profile-stat-icon">❤️</span>
                    <span class="profile-stat-number">{{ app.user.articleLikes|length }}</span>
                    <span class="profile-stat-text">Likes</span>
                </div>
                <div class="profile-stat-card">
                    <span class="profile-stat-icon">👁️</span>
                    <span class="profile-stat-number">{{ app.user.articleVues|length }}</span>
                    <span class="profile-stat-text">Vues</span>
                </div>
            </div>
            <div style="margin-top: 30px;">
                <a href="{{ path('app_logout') }}" class="btn-logout">Déconnexion</a>
            </div>
        {% else %}
            <div style="text-align: center; padding: 20px 0;">
                <div class="profile-avatar-large" style="background-color: var(--gray-light); color: var(--text-secondary);">
                    ?
                </div>
                <p style="margin: 20px 0; font-size: 0.95rem; color: var(--text-secondary);">Vous n'êtes pas connecté à votre compte Diamond Forum.</p>
                <a href="{{ path('app_login') }}" class="btn" style="display: block; text-align: center; text-decoration: none; background-color: var(--accent-green); color: white; border-radius: 6px; padding: 12px; font-weight: 600;">Se Connecter</a>
                <a href="{{ path('app_register') }}" style="display: inline-block; margin-top: 15px; text-decoration: underline; color: var(--accent-green); font-size: 0.9rem; font-weight: 600;">Créer un compte</a>
            </div>
        {% endif %}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const profileToggle = document.getElementById('profileToggle');
    const profileClose = document.getElementById('profileClose');
    const profileDrawer = document.getElementById('profileDrawer');
    const profileBackdrop = document.getElementById('profileBackdrop');

    function openDrawer() {
        profileDrawer.classList.add('open');
        profileBackdrop.classList.add('open');
        document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
        profileDrawer.classList.remove('open');
        profileBackdrop.classList.remove('open');
        document.body.style.overflow = '';
    }

    if (profileToggle) {
        profileToggle.addEventListener('click', openDrawer);
    }
    if (profileClose) {
        profileClose.addEventListener('click', closeDrawer);
    }
    if (profileBackdrop) {
        profileBackdrop.addEventListener('click', closeDrawer);
    }
});
</script>
{% endblock %}
