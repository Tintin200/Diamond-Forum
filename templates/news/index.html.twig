{% extends 'base.html.twig' %}

{% block title %}Actualités - Diamond Forum{% endblock %}

{% block body %}
<main>
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert {{ label == 'error' ? 'alert-danger' : (label == 'success' ? 'success' : 'warning') }}" style="margin-bottom: 20px;">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 15px;">
        <h1 style="margin: 0;">📡 Actualités et Décryptages du Terrain</h1>
        <a href="{{ path('app_article_new') }}" class="btn">✍️ Publier un Article</a>
    </div>
    <p>Découvrez les dernières dépêches, rumeurs de transfert et résumés de matchs analysés par nos experts.</p>

    {% if headlineArticles is not empty %}
    <section>
        <h2>À la Une (Officiel)</h2>
        {% for article in headlineArticles %}
            <article class="card mb">
                <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 15px;">
                    <div>
                        {% if article.tags %}
                            {% for tag in article.tags|split(',') %}
                                <span class="badge primary">{{ tag|trim }}</span>
                            {% endfor %}
                        {% else %}
                            <span class="badge primary">À la Une</span>
                        {% endif %}
                    </div>
                    <span class="text-secondary" style="font-size: 0.9rem;">Publié par <strong>{{ article.auteur }}</strong></span>
                </div>
                {% if article.image %}
                    <div style="margin-bottom: 15px; border-radius: 8px; overflow: hidden; max-height: 350px;">
                        <img src="{{ article.image }}" alt="{{ article.sujet }}" style="width: 100%; height: auto; object-fit: cover;" />
                    </div>
                {% endif %}
                <h3 style="font-size: 1.3rem; margin-bottom: 10px; color: var(--primary-dark);">{{ article.sujet }}</h3>
                <p style="white-space: pre-line; color: var(--text-secondary);">{{ article.contenu }}</p>
                {% if app.user and (article.author == app.user or is_granted('ROLE_ADMIN')) %}
                    <div style="display: flex; gap: 10px; margin-top: 15px; border-top: 1px solid var(--border-color); padding-top: 15px; justify-content: flex-end;">
                        <a href="{{ path('app_article_edit', {id: article.id}) }}" class="btn primary" style="font-size: 0.85rem; padding: 6px 12px; background-color: var(--accent-green);">✏️ Modifier</a>
                        
                        <form method="post" action="{{ path('app_article_delete', {id: article.id}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet article ? Cette action est irréversible.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
                            <button type="submit" class="btn danger" style="font-size: 0.85rem; padding: 6px 12px; background-color: var(--accent-red); color: white; border: none; cursor: pointer; border-radius: 6px; font-weight: 600;">🗑️ Supprimer</button>
                        </form>
                    </div>
                {% endif %}
            </article>
        {% endfor %}
    </section>
    {% endif %}

    {% if communityArticles is not empty %}
    <section>
        <h2>Publications de la Communauté</h2>
        {% for article in communityArticles %}
            <article class="card mb">
                <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 15px;">
                    <div>
                        {% if article.tags %}
                            {% for tag in article.tags|split(',') %}
                                <span class="badge primary">{{ tag|trim }}</span>
                            {% endfor %}
                        {% else %}
                            <span class="badge primary">Article</span>
                        {% endif %}
                    </div>
                    <span class="text-secondary" style="font-size: 0.9rem;">Publié par <strong>{{ article.auteur }}</strong></span>
                </div>
                {% if article.image %}
                    <div style="margin-bottom: 15px; border-radius: 8px; overflow: hidden; max-height: 350px;">
                        <img src="{{ article.image }}" alt="{{ article.sujet }}" style="width: 100%; height: auto; object-fit: cover;" />
                    </div>
                {% endif %}
                <h3 style="font-size: 1.3rem; margin-bottom: 10px; color: var(--primary-dark);">{{ article.sujet }}</h3>
                <p style="white-space: pre-line; color: var(--text-secondary);">{{ article.contenu }}</p>
                {% if app.user and (article.author == app.user or is_granted('ROLE_ADMIN')) %}
                    <div style="display: flex; gap: 10px; margin-top: 15px; border-top: 1px solid var(--border-color); padding-top: 15px; justify-content: flex-end;">
                        <a href="{{ path('app_article_edit', {id: article.id}) }}" class="btn primary" style="font-size: 0.85rem; padding: 6px 12px; background-color: var(--accent-green);">✏️ Modifier</a>
                        
                        <form method="post" action="{{ path('app_article_delete', {id: article.id}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet article ? Cette action est irréversible.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
                            <button type="submit" class="btn danger" style="font-size: 0.85rem; padding: 6px 12px; background-color: var(--accent-red); color: white; border: none; cursor: pointer; border-radius: 6px; font-weight: 600;">🗑️ Supprimer</button>
                        </form>
                    </div>
                {% endif %}
            </article>
        {% endfor %}
    </section>
    {% endif %}


    <section>
        <h2>Catégories Populaires</h2>
        <div class="grid">
            <div class="card">
                <h3 style="margin-top: 0;">Analyses de Match</h3>
                <p class="text-secondary mb">Mis à jour quotidiennement</p>
                <p>Décryptage tactique des lancers et des choix stratégiques des managers de la MLB.</p>
            </div>

            <div class="card">
                <h3 style="margin-top: 0;">Rumeurs & Transferts</h3>
                <p class="text-secondary mb">Alertes en temps réel</p>
                <p>Suivez les coulisses des négociations d'agents et les futurs mouvements des joueurs vedettes.</p>
            </div>

            <div class="card">
                <h3 style="margin-top: 0;">Sabermetrics & Stats</h3>
                <p class="text-secondary mb">Hebdomadaire</p>
                <p>Pour les amateurs de chiffres : analyses poussées des statistiques de WHIP, ERA et WAR.</p>
            </div>

            <div class="card">
                <h3 style="margin-top: 0;">Focus Équipes</h3>
                <p class="text-secondary mb">Mensuel</p>
                <p>Analyses approfondies sur l'état de forme et les finances des 30 franchises de la MLB.</p>
            </div>

            <div class="card">
                <h3 style="margin-top: 0;">Légendes du Baseball</h3>
                <p class="text-secondary mb">Rétrospective</p>
                <p>Redécouvrez les carrières exceptionnelles des icônes qui ont marqué l'histoire du jeu.</p>
            </div>

            <div class="card">
                <h3 style="margin-top: 0;">Stades Historiques</h3>
                <p class="text-secondary mb">Reportage</p>
                <p>Un voyage à travers les parcs et terrains légendaires des États-Unis et du monde entier.</p>
            </div>
        </div>
    </section>
</main>
{% endblock %}
